{
  "name": "cyber-guardians-mobile",
  "version": "1.0.0",
  "description": "لعبة تعليمية تفاعلية لتعليم أساسيات الأمن السيبراني",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "npm run build && wrangler dev",
