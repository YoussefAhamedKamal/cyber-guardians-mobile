    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wrangler": "^4.99.0"
  }
}
