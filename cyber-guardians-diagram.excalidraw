    {
      "id": "win_text",
      "type": "text",
      "x": 100,
      "y": 1480,
      "width": 1060,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "m2",
      "roundness": null,
      "seed": 912,
      "version": 1,
      "versionNonce": 912,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "الخطوة 1: تثبيت Node.js\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. افتح المتصفح وانتقل إلى:\n   https://nodejs.org\n2. حمّل LTS (الإصدار طويل الأمد)\n3. شغّل الملف .msi واتبع التثبيت\n4. اضغط \"Next\" في كل الخطوات\n5. أعد تشغيل الكمبيوتر\n\nالخطوة 2: تثبيت Git\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. انتقل إلى:\n   https://git-scm.com/download/win\n2. حمّل الملف وتثبته\n3. اترك الإعدادات الافتراضية\n\nالخطوة 3: تثبيت المحرر (اختياري)\n━━━━━━━━━━━━━━━━━━━━━━━━━\n• VS Code: https://code.visualstudio.com\n  (يأتي مع Terminal مدمج)\n\nالخطوة 4: تشغيل اللعبة\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. افتح PowerShell أو CMD\n2. اكتب:\n   git clone https://github.com/YoussefAhamedKamal/cyber-guardians-mobile.git\n   cd cyber-guardians-mobile\n   npm install\n   npm run dev\n3. افتح المتصفح على:\n   http://localhost:5173",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "الخطوة 1: تثبيت Node.js\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. افتح المتصفح وانتقل إلى:\n   https://nodejs.org\n2. حمّل LTS (الإصدار طويل الأمد)\n3. شغّل الملف .msi واتبع التثبيت\n4. اضغط \"Next\" في كل الخطوات\n5. أعد تشغيل الكمبيوتر\n\nالخطوة 2: تثبيت Git\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. انتقل إلى:\n   https://git-scm.com/download/win\n2. حمّل الملف وتثبته\n3. اترك الإعدادات الافتراضية\n\nالخطوة 3: تثبيت المحرر (اختياري)\n━━━━━━━━━━━━━━━━━━━━━━━━━\n• VS Code: https://code.visualstudio.com\n  (يأتي مع Terminal مدمج)\n\nالخطوة 4: تشغيل اللعبة\n━━━━━━━━━━━━━━━━━━━━━━━━━\n1. افتح PowerShell أو CMD\n2. اكتب:\n   git clone https://github.com/YoussefAhamedKamal/cyber-guardians-mobile.git\n   cd cyber-guardians-mobile\n   npm install\n   npm run dev\n3. افتح المتصفح على:\n   http://localhost:5173",
      "autoResize": true,
      "lineHeight": 1.25
    },

